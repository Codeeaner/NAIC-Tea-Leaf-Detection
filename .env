# Tea Leaf Detection Application Configuration

# Database Configuration
DATABASE_URL=sqlite:///./tea_leaf_detection.db

# Model Configuration
# Leave blank to let the app auto-select the newest trained model.
CONFIDENCE_THRESHOLD=0.25

# File Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.webp
MAX_BATCH_SIZE=50

# Directory Configuration
UPLOAD_DIR=uploads
RESULTS_DIR=results
REPORTS_DIR=reports

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# CORS Configuration
ALLOWED_ORIGINS=*

# Logging Configuration
LOG_LEVEL=INFO